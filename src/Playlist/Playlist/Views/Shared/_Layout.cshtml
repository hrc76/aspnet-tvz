<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MusicBar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Playlist.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header>
            <nav class="navbar navbar-expand-lg app-navbar">
                <div class="container-fluid">
                    <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="brand-mark">♪</span>
                        MusicBar
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav ms-auto align-items-center">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Song" asp-action="Index">Songs</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Artist" asp-action="Index">Artists</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Album" asp-action="Index">Albums</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Genre" asp-action="Index">Genres</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Playlist" asp-action="Index">Playlists</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="User" asp-action="Index">Users</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ListeningHistory" asp-action="Index">History</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="app-main">
            <div class="container app-container">
                <div class="page-content">
                    @RenderBody()
                </div>
            </div>
        </main>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - MusicBar - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
