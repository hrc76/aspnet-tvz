@using Playlist.Models
@model Playlist

<h1>@Model.Name</h1>

<p><strong>Description:</strong> @Model.Description</p>

<p>
    <strong>Owner:</strong>
    <a asp-controller="User" asp-action="Details" asp-route-id="@Model.Owner.UserId">
        @Model.Owner.Username
    </a>
</p>

<p><strong>Created At:</strong> @Model.CreatedAt.ToShortDateString()</p>
<p><strong>Public:</strong> @(Model.IsPublic ? "Yes" : "No")</p>
<p><strong>Likes:</strong> @Model.Likes</p>

<h2>Songs</h2>
@if (Model.Songs != null && Model.Songs.Any())
{
    <ul>
        @foreach (var song in Model.Songs)
        {
            <li>
                <a asp-controller="Song" asp-action="Details" asp-route-id="@song.SongId">
                    @song.Title
                </a>
                - @song.Artist.StageName
            </li>
        }
    </ul>
}
else
{
    <p>No songs in this playlist.</p>
}

<p>
    <a asp-controller="Playlist" asp-action="Index">Back to Playlists</a>
</p>